<LoginScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: '30dp'
        spacing: '10dp'
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Widget:
            size_hint_y: 0.1

        Label:
            text: "Welcome Back"
            font_size: '32sp'
            bold: True
            color: 0.1, 0.1, 0.1, 1
            halign: 'left'
            size_hint_y: None
            height: self.texture_size[1]
            text_size: self.width, None

        Label:
            text: "Sign in to continue"
            font_size: '16sp'
            color: 0.5, 0.5, 0.5, 1
            halign: 'left'
            size_hint_y: None
            height: '30dp'
            text_size: self.width, None

        Widget:
            size_hint_y: None
            height: '30dp'

        # Email Section
        Label:
            text: "Email"
            font_size: '14sp'
            bold: True
            color: 0.2, 0.2, 0.2, 1
            halign: 'left'
            size_hint_y: None
            height: '20dp'
            text_size: self.width, None
        
        TextInput:
            id: email
            hint_text: "Enter your email"
            multiline: False
            size_hint_y: None
            height: '45dp'
            write_tab: False
            # Simple styling to approximate the look
            background_normal: ''
            background_active: ''
            background_color: 0.96, 0.96, 0.96, 1
            foreground_color: 0.2, 0.2, 0.2, 1
            padding_y: [self.height / 2.0 - (self.line_height / 2.0) * len(self._lines), 0]
            padding_x: '15dp'

        Widget:
            size_hint_y: None
            height: '15dp'

        # Password Section
        Label:
            text: "Password"
            font_size: '14sp'
            bold: True
            color: 0.2, 0.2, 0.2, 1
            halign: 'left'
            size_hint_y: None
            height: '20dp'
            text_size: self.width, None
        
        TextInput:
            id: password
            hint_text: "Enter your password"
            password: True
            multiline: False
            size_hint_y: None
            height: '45dp'
            write_tab: False
            background_normal: ''
            background_active: ''
            background_color: 0.96, 0.96, 0.96, 1
            foreground_color: 0.2, 0.2, 0.2, 1
            padding_y: [self.height / 2.0 - (self.line_height / 2.0) * len(self._lines), 0]
            padding_x: '15dp'

        Widget:
            size_hint_y: None
            height: '10dp'

        # Remember Me and Forgot Password
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '30dp'
            
            BoxLayout:
                orientation: 'horizontal'
                size_hint_x: None
                width: '130dp'
                CheckBox:
                    size_hint_x: None
                    width: '30dp'
                    color: 0, 0.48, 1, 1
                Label:
                    text: "Remember me"
                    font_size: '13sp'
                    color: 0.5, 0.5, 0.5, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size
            
            Widget:
                # Spacer
            
            Button:
                text: "Forgot Password?"
                font_size: '13sp'
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0, 0.48, 1, 1
                size_hint_x: None
                width: '120dp'
                halign: 'right'
                valign: 'middle'
                # text_size: self.size

        Widget:
            size_hint_y: None
            height: '30dp'

        Button:
            text: "Sign In"
            bold: True
            font_size: '16sp'
            size_hint_y: None
            height: '50dp'
            background_normal: ''
            background_color: 0, 0.48, 1, 1
            on_release: app.root.current = 'home'

        Widget:
            size_hint_y: 0.1

        # Footer
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '30dp'
            spacing: '5dp'
            pos_hint: {'center_x': 0.5}
            size_hint_x: None
            width: self.minimum_width
            
            Label:
                text: "Don't have an account?"
                font_size: '14sp'
                color: 0.5, 0.5, 0.5, 1
                size_hint_x: None
                width: self.texture_size[0]
            
            Button:
                text: "Sign Up"
                font_size: '14sp'
                bold: True
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 0, 0.48, 1, 1
                size_hint_x: None
                width: self.texture_size[0]
                on_release: app.root.current = 'signup'

        Widget:
            size_hint_y: 0.2
