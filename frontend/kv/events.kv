<EventItem@BoxLayout>:
    orientation: 'horizontal'
    size_hint_y: None
    height: 60
    padding: 10
    spacing: 10
    event_id: None
    text: ''
    
    Label:
        text: root.text
        size_hint_x: 0.8
        halign: 'left'
        valign: 'middle'
        text_size: self.size

    Button:
        text: "View"
        size_hint_x: 0.2
        on_release: app.root.get_screen('event_list').view_event(root.event_id)

<EventListScreen>:
    BoxLayout:
        orientation: 'vertical'
        
        ActionBar:
            ActionView:
                use_separator: True
                ActionPrevious:
                    title: 'Events'
                    with_previous: False
                ActionOverflow:
                ActionButton:
                    text: 'Refresh'
                    on_release: root.refresh()
                ActionButton:
                    text: 'Add'
                    on_release: root.add_event()
                ActionButton:
                    text: 'Logout'
                    on_release: app.root.current = 'login'

        RecycleView:
            viewclass: 'EventItem'
            data: [{'text': f"{event['title']} - {event['start_date']}", 'event_id': event['id']} for event in root.events]
            RecycleBoxLayout:
                default_size: None, dp(56)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'

<EventDetailScreen>:
    BoxLayout:
        orientation: 'vertical'
        
        ActionBar:
            ActionView:
                use_separator: True
                ActionPrevious:
                    title: 'Event Details'
                    with_previous: True
                    on_release: root.cancel()

        ScrollView:
            GridLayout:
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                padding: 20
                spacing: 20

                Label:
                    text: "Title"
                    size_hint_y: None
                    height: 30
                TextInput:
                    id: title_input
                    size_hint_y: None
                    height: 40
                    multiline: False

                Label:
                    text: "Description"
                    size_hint_y: None
                    height: 30
                TextInput:
                    id: description_input
                    size_hint_y: None
                    height: 100
                    multiline: True

                Label:
                    text: "Location"
                    size_hint_y: None
                    height: 30
                TextInput:
                    id: location_input
                    size_hint_y: None
                    height: 40
                    multiline: False

                Label:
                    text: "Start Date (YYYY-MM-DDTHH:MM:SSZ)"
                    size_hint_y: None
                    height: 30
                TextInput:
                    id: start_date_input
                    size_hint_y: None
                    height: 40
                    multiline: False

                Label:
                    text: "End Date (YYYY-MM-DDTHH:MM:SSZ)"
                    size_hint_y: None
                    height: 30
                TextInput:
                    id: end_date_input
                    size_hint_y: None
                    height: 40
                    multiline: False

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 50
                    spacing: 20
                    
                    Button:
                        text: "Save"
                        on_release: root.save_event()
                    
                    Button:
                        text: "Delete"
                        background_color: 1, 0, 0, 1
                        on_release: root.delete_event()
                        opacity: 1 if root.event_id else 0
                        disabled: not root.event_id
